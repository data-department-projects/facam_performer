# ─────────────────────────────────────────────────────────────
# FACAM PERFORMER — Variables d'environnement
# Copiez ce fichier en .env.local et renseignez vos valeurs.
# NE JAMAIS committer .env.local dans git.
# ─────────────────────────────────────────────────────────────

# ── Supabase ──────────────────────────────────────────────────
# Trouvez ces valeurs dans : Supabase → Settings → API
VITE_SUPABASE_URL="https://faqlafabgmlfxnyyvznq.supabase.co"
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ── Resend (email transactionnel — côté serveur uniquement) ───
# Créez votre clé sur : https://resend.com/api-keys
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Adresse expéditeur vérifiée dans Resend (doit correspondre à votre domaine)
RESEND_FROM_EMAIL=FACAM PERFORMER <no-reply@votredomaine.com>

# Email de l'équipe support qui reçoit les signalements d'erreurs
SUPPORT_EMAIL=support@votredomaine.com

# ── Supabase Service Role (côté serveur uniquement — NE PAS exposer) ──
# Trouvez cette valeur dans : Supabase → Settings → API → service_role
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Secret partagé entre Supabase Auth Hook et votre route Vercel /api/auth-email
# Générez une valeur aléatoire : openssl rand -base64 32
# À configurer dans : Supabase → Auth → Hooks → Send Email → Secret
SUPABASE_HOOK_SECRET=votre-secret-aleatoire-32-caracteres

# ── Clé IA (chatbot + analyse hebdo + sécurité) ───────────────
# Votre clé Lovable API (gateway vers Google Gemini)
LOVABLE_API_KEY=lv_xxxxxxxxxxxxxxxxxxxx

# ── Backup ────────────────────────────────────────────────────
# Secret pour protéger la route /api/backup (cron ou appel admin)
# Générez : openssl rand -base64 32
BACKUP_SECRET=votre-secret-backup-aleatoire

# ── Environnement (optionnel) ──────────────────────────────────
# VITE_APP_ENV=development
